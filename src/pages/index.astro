---
import MainLayout from '../layouts/MainLayout.astro';
import MarkdownPage from '../components/MarkdownPage.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'home');

if (!entry) {
	throw new Error('Missing content entry: pages/home.md');
}

const { Content } = await render(entry);
const { hero, intro, themes, relevance } = entry.data;
const hasStructuredHomepage = hero && intro && themes && relevance;
const readingPaths = [
	{
		label: 'Start Here',
		description:
			'A first orientation to what Fractalism is, how it should be read, and where it can go wrong.',
		links: [
			{ href: '/introduction', label: 'Introduction' },
			{ href: '/how-to-read-fractalism', label: 'How to Read Fractalism' },
			{ href: '/where-fractalism-can-be-wrong', label: 'Where Fractalism Can Be Wrong' },
			{ href: '/truth', label: 'Truth' },
			{ href: '/friction-as-signal', label: 'Friction as Signal' },
		],
	},
	{
		label: 'Practical',
		description:
			'For readers who want clarity, sobriety, attention, and immediately usable distinctions.',
		links: [
			{ href: '/truth', label: 'Truth' },
			{ href: '/the-void', label: 'The Void' },
			{ href: '/friction-as-signal', label: 'Friction as Signal' },
			{ href: '/living-fractalism', label: 'Living Fractalism' },
			{ href: '/sobriety', label: 'Sobriety' },
			{ href: '/what-you-can-concretely-do-in-the-void', label: 'What You Can Concretely Do in the Void' },
		],
	},
	{
		label: 'Core Architecture',
		description:
			'For readers who want the framework itself: its concepts, structure, and inner logic.',
		links: [
			{ href: '/introduction', label: 'Introduction' },
			{ href: '/concepts', label: 'Core Concepts' },
			{ href: '/the-structure-of-fractalism', label: 'The Structure of Fractalism' },
			{ href: '/attention-as-a-resource', label: 'Attention as a Resource' },
			{ href: '/community', label: 'Community' },
		],
	},
	{
		label: 'Exploratory',
		description:
			'For the higher and more speculative range of Fractalism. Best read after the grounding pages are in place.',
		links: [
			{ href: '/the-void', label: 'The Void' },
			{ href: '/the-source', label: 'The Source' },
			{ href: '/the-source-in-you', label: 'The Source in You' },
			{ href: '/vril', label: 'Vril' },
			{ href: '/diamond-soul', label: 'Diamond Soul' },
			{ href: '/loosh', label: 'Loosh' },
			{ href: '/the-demiurge', label: 'The Demiurge' },
			{ href: '/archons', label: 'Archons' },
			{ href: '/black-diamond-soul', label: 'Black Diamond Soul' },
		],
	},
];
---

<MainLayout
	title={entry.data.title}
	description={entry.data.description}
>
	{
		hasStructuredHomepage ? (
			<>
				<section class="hero" style="width:100%">
					<div class="hero__inner">
						<p class="eyebrow">{hero.eyebrow}</p>
						<h1>{hero.title}</h1>
						<p class="hero__subtitle">{hero.subtitle}</p>
						<p class="hero__intro">{hero.intro}</p>
						<div class="cta-row">
							<a class="button-link button-link--primary" href={hero.primaryCta.href}>
								{hero.primaryCta.label}
							</a>
							<a class="button-link button-link--secondary" href={hero.secondaryCta.href}>
								{hero.secondaryCta.label}
							</a>
						</div>
					</div>
				</section>

				<section class="section-stack">
					<div class="section-heading">
						<p class="eyebrow">{intro.eyebrow}</p>
						<h2>{intro.heading}</h2>
					</div>
					<div class="prose-block">
						<p>{intro.paragraphs[0]}</p>
						<p>{intro.paragraphs[1]}</p>
					</div>
				</section>

				<section class="section-stack">
					<div class="section-heading">
						<p class="eyebrow">{themes.eyebrow}</p>
						<h2>{themes.heading}</h2>
					</div>
				</section>

				<section class="section-grid">
					{
						themes.cards.map((card) => (
							<article class="theme-card">
								<h3>{card.title}</h3>
								<p>{card.text}</p>
							</article>
						))
					}
				</section>

				<section class="section-stack">
					<div class="section-heading">
						<p class="eyebrow">{relevance.eyebrow}</p>
						<h2>{relevance.heading}</h2>
					</div>
					<div class="prose-block">
						<p>{relevance.paragraph}</p>
						<p>{relevance.closing}</p>
					</div>
				</section>

				<section class="section-stack">
					<div class="section-heading">
						<p class="eyebrow">Reading Paths</p>
						<h2>Different ways into the structure</h2>
					</div>
					<div class="section-grid">
						{
							readingPaths.map((path) => (
								<article class="theme-card">
									<h3>{path.label}</h3>
									<p>{path.description}</p>
									<ul>
										{
											path.links.map((link) => (
												<li><a href={link.href}>{link.label}</a></li>
											))
										}
									</ul>
								</article>
							))
						}
					</div>
				</section>

				<section class="section-stack">
					<div class="section-heading">
						<p class="eyebrow">Markdown</p>
						<h2>Working Draft</h2>
					</div>
					<div class="markdown-shell">
						<Content />
					</div>
				</section>
			</>
		) : (
			<>
				<MarkdownPage
					eyebrow={entry.data.eyebrow ?? 'Fractalism'}
					title={entry.data.title}
					description={entry.data.description}
				>
					<Content />
				</MarkdownPage>
			</>
		)
	}
</MainLayout>
