---
import MainLayout from '../layouts/MainLayout.astro';
import MarkdownPage from '../components/MarkdownPage.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'team-3');

if (!entry) {
	throw new Error('Missing content entry: pages/team-3.md');
}

const { Content } = await render(entry);
---

<MainLayout title={`${entry.data.title} | Fractalism`} description={entry.data.description}>
	<MarkdownPage
		eyebrow={entry.data.eyebrow}
		title={entry.data.title}
		description={entry.data.description}
	>
		<Content />
	</MarkdownPage>
</MainLayout>
