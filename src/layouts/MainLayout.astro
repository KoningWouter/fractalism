---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Fractalism',
	description = 'Fractalism is a living framework for truth, resonance, inner sovereignty, and the rebuilding of human community beyond inversion.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{title}</title>
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-BS5JXEBCQD"></script>
		<script>
		window.dataLayer = window.dataLayer || [];
		function gtag(){dataLayer.push(arguments);}
		gtag('js', new Date());

		gtag('config', 'G-BS5JXEBCQD');
		</script>
	</head>
	<body>
		<div class="site-shell">
			<Header />
			<main class="page-main">
				<slot />
			</main>
			<Footer />
		</div>
	</body>
</html>
