---
interface Props {
	eyebrow?: string;
	title: string;
	description?: string;
}

const { eyebrow = 'Fractalism', title, description } = Astro.props;
const pageUrl = Astro.url.href;
---

<section class="content-shell">
	<div class="section-heading section-heading--page">
		<p class="eyebrow">{eyebrow}</p>
		<h1 class="content-title">{title}</h1>
		{description && <p class="section-copy section-copy--page">{description}</p>}
	</div>

	<div class="page-breath" aria-hidden="true">
		<img class="page-breath__icon" src="/divider-phi.svg" alt="" data-lightbox-ignore="true" />
	</div>

	<div class="markdown-shell">
		<slot />

		<hr>

		<div id="fractal-graph-container" style="width: 100%; height: 400px; background: #fefcf9; position: relative; overflow: hidden; border: 1px solid #eee; border-radius: 8px; margin-top: 2rem;">
    <svg id="fractal-graph"></svg>
</div>

<script src="https://d3js.org/d3.v7.min.js"></script>
<script>
    const fractalData = {
        nodes: [
            { id: "Fractalism", label: "Fractalism", url: "/", group: "core", size: 8 },
            { id: "Introduction", label: "Introduction", url: "/introduction", group: "foundations", size: 5 },
            { id: "Truth", label: "Truth", url: "/truth", group: "foundations", size: 5 },
            { id: "Attention", label: "Attention Loops", url: "/attention-loops", group: "foundations", size: 5 },
            { id: "Void", label: "The Void", url: "/the-void", group: "foundations", size: 5 },
            { id: "Source", label: "The Source", url: "/the-source", group: "source", size: 6 },
            { id: "Vril", label: "Vril", url: "/vril", group: "source", size: 4 },
            { id: "Diamond", label: "Diamond Soul", url: "/diamond-soul", group: "source", size: 4 },
            { id: "Demiurge", label: "The Demiurge", url: "/the-demiurge", group: "demiurge", size: 6 },
            { id: "Loosh", label: "Loosh", url: "/loosh", group: "demiurge", size: 4 },
            { id: "Archons", label: "Archons", url: "/archons", group: "demiurge", size: 4 },
            { id: "Team3", label: "Team 3", url: "/team-3-architecture", group: "practice", size: 5 },
            { id: "Gnosis", label: "Liquid Gnosis", url: "/liquid-gnosis-method", group: "practice", size: 5 },
            { id: "Sobriety", label: "Sobriety", url: "/sobriety", group: "practice", size: 4 }
        ],
        links: [
            { source: "Fractalism", target: "Introduction" },
            { source: "Fractalism", target: "Source" },
            { source: "Fractalism", target: "Demiurge" },
            { source: "Fractalism", target: "Team3" },
            { source: "Introduction", target: "Truth" },
            { source: "Introduction", target: "Attention" },
            { source: "Attention", target: "Void" },
            { source: "Source", target: "Vril" },
            { source: "Source", target: "Diamond" },
            { source: "Source", target: "Void" },
            { source: "Demiurge", target: "Loosh" },
            { source: "Demiurge", target: "Archons" },
            { source: "Demiurge", target: "Attention" },
            { source: "Team3", target: "Gnosis" },
            { source: "Gnosis", target: "Void" },
            { source: "Team3", target: "Sobriety" }
        ]
    };

    const container = d3.select("#fractal-graph-container");
    const svg = d3.select("#fractal-graph");
    
    const accentColor = "#d4af37"; // Gnosis Gold
    const baseLinkColor = "#eeeeee";
    const baseNodeColor = "#333333";
    const labelColor = "#888888";

    function updateGraph() {
        const width = container.node().clientWidth;
        const height = container.node().clientHeight;
        svg.attr("width", width).attr("height", height);

        const simulation = d3.forceSimulation(fractalData.nodes)
            .force("link", d3.forceLink(fractalData.links).id(d => d.id).distance(120))
            .force("charge", d3.forceManyBody().strength(-300))
            .force("center", d3.forceCenter(width / 2, height / 2))
            .force("collision", d3.forceCollide().radius(50));

        svg.selectAll("*").remove();

        const link = svg.append("g")
            .selectAll("line")
            .data(fractalData.links)
            .join("line")
            .attr("stroke", baseLinkColor)
            .attr("stroke-width", 1);

        const node = svg.append("g")
            .selectAll("circle")
            .data(fractalData.nodes)
            .join("circle")
            .attr("r", d => d.size)
            .attr("fill", baseNodeColor)
            .attr("cursor", "pointer")
            .call(drag(simulation));

        const label = svg.append("g")
            .selectAll("text")
            .data(fractalData.nodes)
            .join("text")
            .text(d => d.label)
            .attr("font-size", "11px")
            .attr("font-family", "'Inter', sans-serif")
            .attr("fill", labelColor)
            .attr("dx", 12)
            .attr("dy", 4)
            .attr("cursor", "pointer")
            .style("pointer-events", "none");

        node.on("mouseover", (event, d) => {
            node.transition().duration(420).attr("fill", n => (n === d || isConnected(d, n) ? accentColor : "#ddd"));
            label.transition().duration(420).attr("fill", n => (n === d || isConnected(d, n) ? "#111" : "#bbb"));
            link.transition().duration(420)
                .attr("stroke", l => (l.source.id === d.id || l.target.id === d.id ? accentColor : baseLinkColor))
                .attr("stroke-width", l => (l.source.id === d.id || l.target.id === d.id ? 2 : 1));
        })
        .on("mouseout", () => {
            node.transition().duration(420).attr("fill", baseNodeColor);
            label.transition().duration(420).attr("fill", labelColor);
            link.transition().duration(420).attr("stroke", baseLinkColor).attr("stroke-width", 1);
        })
        .on("click", (event, d) => {
            window.location.href = d.url;
        });

        simulation.on("tick", () => {
            link.attr("x1", d => d.source.x)
                .attr("y1", d => d.source.y)
                .attr("x2", d => d.target.x)
                .attr("y2", d => d.target.y);

            node.attr("cx", d => d.x).attr("cy", d => d.y);
            label.attr("x", d => d.x).attr("y", d => d.y);
        });

        function isConnected(a, b) {
            return fractalData.links.some(l => 
                (l.source.id === a.id && l.target.id === b.id) || 
                (l.source.id === b.id && l.target.id === a.id)
            );
        }
    }

    function drag(simulation) {
        return d3.drag()
            .on("start", (event) => {
                if (!event.active) simulation.alphaTarget(0.3).restart();
                event.subject.fx = event.subject.x;
                event.subject.fy = event.subject.y;
            })
            .on("drag", (event) => {
                event.subject.fx = event.x;
                event.subject.fy = event.y;
            })
            .on("end", (event) => {
                if (!event.active) simulation.alphaTarget(0);
                event.subject.fx = null;
                event.subject.fy = null;
            });
    }

    window.addEventListener("resize", updateGraph);
    updateGraph();
</script>
	</div>

	<div class="cite-block">
		<p class="cite-block__label">Link to this page</p>
		<div class="cite-block__row">
			<code class="cite-block__url" id="cite-url">{pageUrl}</code>
			<button class="cite-block__copy" type="button" data-url={pageUrl} aria-label="Copy link">
				<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
					<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
				</svg>
			</button>
		</div>
	</div>
</section>

<script>
	document.querySelectorAll<HTMLButtonElement>('.cite-block__copy').forEach((btn) => {
		const icon = btn.querySelector('svg');
		btn.addEventListener('click', async () => {
			const url = btn.dataset.url ?? '';
			await navigator.clipboard.writeText(url);
			if (icon) icon.style.opacity = '0.4';
			setTimeout(() => {
				if (icon) icon.style.opacity = '';
			}, 2000);
		});
	});
</script>
