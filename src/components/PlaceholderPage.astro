---
interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---

<section class="content-shell">
	<div class="section-heading">
		<p class="eyebrow">Fractalism</p>
		<h1>{title}</h1>
	</div>

	<div class="prose-block">
		<p>{description}</p>
		<p>
			This section is being prepared as part of the first public structure of the site. It will
			expand into a fuller body of texts, definitions, and linked essays.
		</p>
	</div>
</section>
