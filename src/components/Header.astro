---
const navItems = [
	{ href: '/', label: 'Home' },
	{
		label: 'Begin Here',
		items: [
			{ href: '/introduction', label: 'Introduction' },
			{ href: '/how-to-read-fractalism', label: 'How to Read' },
			{ href: '/where-fractalism-can-be-wrong', label: 'Where It Can Be Wrong' },
			{ href: '/faq', label: 'FAQ' },
		],
	},
	{
		label: 'Foundations',
		items: [
			{ href: '/the-source', label: 'The Source (Reality)' },
			{ href: '/the-manasaputra', label: 'The Manasaputra' },
			{ href: '/the-demiurge', label: 'The Demiurge (Distortion)' },
			{ href: '/the-void', label: 'The Void' },
			{ href: '/attention-loops', label: 'Attention Loops' },
			{ href: '/synchronicity', label: 'Synchronicity' },
			{ href: '/truth', label: 'Truth' },
			{ href: '/field-quality', label: 'Field Quality' },
		],
	},
	{
		label: 'Practice',
		items: [
			{ href: '/team-3-architecture', label: 'Team 3 Method' },
			{ href: '/liquid-gnosis-method', label: 'Liquid Gnosis' },
			{ href: '/i-am-the-formula', label: 'I Am the Formula' },
			{ href: '/sobriety', label: 'Sobriety' },
			{ href: '/epistemic-hygiene', label: 'Epistemic Hygiene' },
		],
	},
	{
		label: 'Library',
		items: [
			{ href: '/essays', label: 'Essays' },
			{ href: '/axioms', label: 'Axioms' },
			{ href: '/about', label: 'About' },
			{ href: '/not-a-religion-but-a-living-truth-system', label: 'Not a Religion' },
			{ href: '/the-structure-of-fractalism', label: 'Site Architecture' },
		],
	},
	{
		label: 'Network',
		items: [
			{ href: '/nostr', label: 'Nostr' },
			{ href: '/forum', label: 'Forum' },
			{ href: '/community', label: 'Community/Discord' },
		],
	},
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
	<div class="site-header__inner">
		<a class="site-brand" href="/" aria-label="Fractalism home">
			<span class="site-brand__mark" aria-hidden="true">∞</span>
			<span>Fractalism</span>
		</a>

		<button class="site-nav__toggle" type="button" aria-expanded="false" aria-controls="site-nav" aria-label="Open menu">
			<span class="site-nav__toggle-bars" aria-hidden="true">
				<span class="site-nav__toggle-line"></span>
				<span class="site-nav__toggle-line"></span>
				<span class="site-nav__toggle-line"></span>
			</span>
			<span class="site-nav__toggle-label">Menu</span>
		</button>

		<nav class="site-nav" id="site-nav" aria-label="Primary" data-open="false">
			<ul class="site-nav__list">
				{navItems.map((item) => (
					<li>
						{'href' in item ? (
							<a
								href={item.href}
								class:list={['site-nav__link', { 'is-active': currentPath === item.href }]}
								aria-current={currentPath === item.href ? 'page' : undefined}
							>
								{item.label}
							</a>
						) : (
							<details class="site-nav__group">
								<summary class:list={['site-nav__summary', { 'is-active': item.items.some((child) => child.href === currentPath) }]}>
									{item.label}
								</summary>
								<ul class="site-nav__dropdown">
									{item.items.map((child) => (
										<li>
											<a
												href={child.href}
												class:list={['site-nav__dropdown-link', { 'is-active': currentPath === child.href }]}
												aria-current={currentPath === child.href ? 'page' : undefined}
											>
												{child.label}
											</a>
										</li>
									))}
								</ul>
							</details>
						)}
					</li>
				))}
				<li>
					<button class="theme-toggle" type="button" aria-pressed="false" aria-label="Switch color mode">
						<span class="theme-toggle__label theme-toggle__label--dark">Dark</span>
						<span class="theme-toggle__knob" aria-hidden="true"></span>
						<span class="theme-toggle__label theme-toggle__label--light">Light</span>
					</button>
				</li>
			</ul>
		</nav>
	</div>
</header>

<script>
	const navToggle = document.querySelector('.site-nav__toggle');
	const siteNav = document.querySelector('.site-nav');
	const themeToggle = document.querySelector('.theme-toggle');
	const themeCookieName = 'fractalisme-theme';

	const setThemeCookie = (theme) => {
		document.cookie = `${themeCookieName}=${theme}; path=/; max-age=31536000; SameSite=Lax`;
	};

	const applyThemeState = (theme) => {
		document.documentElement.dataset.theme = theme;
		if (themeToggle) {
			themeToggle.setAttribute('aria-pressed', theme === 'light' ? 'true' : 'false');
		}
	};

	if (themeToggle) {
		themeToggle.addEventListener('click', () => {
			const currentTheme = document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
			const nextTheme = currentTheme === 'light' ? 'dark' : 'light';
			document.documentElement.classList.add('theme-transition');
			applyThemeState(nextTheme);
			setThemeCookie(nextTheme);
			window.setTimeout(() => {
				document.documentElement.classList.remove('theme-transition');
			}, 420);
		});
	}

	if (navToggle && siteNav) {
		const groups = Array.from(siteNav.querySelectorAll('.site-nav__group'));

		const closeNav = () => {
			siteNav.dataset.open = 'false';
			navToggle.setAttribute('aria-expanded', 'false');
		};

		navToggle.addEventListener('click', () => {
			const isOpen = siteNav.dataset.open === 'true';
			siteNav.dataset.open = isOpen ? 'false' : 'true';
			navToggle.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
		});

		groups.forEach((group) => {
			group.addEventListener('toggle', () => {
				if (!group.open) return;
				groups.forEach((otherGroup) => {
					if (otherGroup !== group) otherGroup.open = false;
				});
			});
		});

		document.addEventListener('click', (event) => {
			if (!siteNav.contains(event.target) && !navToggle.contains(event.target)) {
				groups.forEach((group) => {
					group.open = false;
				});
			}
		});

		siteNav.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', closeNav);
		});

		window.addEventListener('resize', () => {
			if (window.innerWidth > 900) closeNav();
		});
	}
</script>
